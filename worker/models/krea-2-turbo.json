{
  "id": "krea-2-turbo",
  "name": "Krea 2 Turbo",
  "capabilities": ["text_to_image"],
  "min_vram_gb": 16,
  "benchmark_only": true,
  "pipeline": "krea2",
  "source": "krea/Krea-2-Turbo",
  "license_id": "krea-2-community",
  "license_url": "https://www.krea.ai/krea-2-licensing",
  "commercial_max_revenue_usd": 1000000,
  "requires_attribution": "Krea 2 is licensed under the Krea 2 Community License Agreement. For more information, visit https://krea.ai/krea-2-licensing.",
  "parameters": {
    "type": "object",
    "properties": {
      "prompt": { "type": "string" },
      "steps": { "type": "integer", "minimum": 4, "maximum": 8, "default": 8 },
      "guidance": { "type": "number", "minimum": 0, "maximum": 2, "default": 0 },
      "seed": { "type": "integer" },
      "width": { "type": "integer", "enum": [1024], "default": 1024 },
      "height": { "type": "integer", "enum": [1024], "default": 1024 }
    },
    "required": ["prompt"]
  }
}
