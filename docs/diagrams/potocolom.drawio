        <mxCell id="vpc" value="VPC eu-west-1" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=none;strokeColor=#8C4FFF;dashed=1;fontColor=#8C4FFF;" vertex="1" parent="1">
          <mxGeometry x="180" y="240" width="640" height="560" as="geometry" />
