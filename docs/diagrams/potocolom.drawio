        </mxCell>
        <mxCell id="moCW" value="CloudWatch - potocolom namespace&#10;fleet aggregates, queue depth, frame p95,&#10;outbox depth, spend pace" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="380" y="174" width="300" height="80" as="geometry" />
        </mxCell>
        <mxCell id="moLogs" value="JSON logs - Logs Insights&#10;per-worker history, forensics" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="380" y="284" width="300" height="50" as="geometry" />
