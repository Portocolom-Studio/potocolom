        <mxCell id="ecs" value="ECS Fargate&#10;API tasks x2" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#ED7100;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.fargate;" vertex="1" parent="1">
          <mxGeometry x="240" y="440" width="70" height="70" as="geometry" />
        </mxCell>
        <mxCell id="priv" value="ECS Fargate&#10;billing + autoscaler&#10;(private repo)" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#ED7100;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.fargate;" vertex="1" parent="1">
          <mxGeometry x="440" y="440" width="70" height="70" as="geometry" />
        </mxCell>
        <mxCell id="rds" value="RDS PostgreSQL&#10;single AZ + PITR" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#C925D1;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.rds;" vertex="1" parent="1">
          <mxGeometry x="240" y="630" width="70" height="70" as="geometry" />
        </mxCell>
        <mxCell id="ec" value="ElastiCache Redis&#10;queues, cache, pub/sub" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#C925D1;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.elasticache;" vertex="1" parent="1">
          <mxGeometry x="440" y="630" width="70" height="70" as="geometry" />
        </mxCell>
        <mxCell id="support" value="Supporting services" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=none;strokeColor=#666666;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="640" y="290" width="160" height="480" as="geometry" />
        </mxCell>
        <mxCell id="ses" value="SES&#10;auth emails" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#DD344C;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.simple_email_service;" vertex="1" parent="1">
          <mxGeometry x="685" y="320" width="60" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ssm" value="SSM&#10;secrets" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#E7157B;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.systems_manager;" vertex="1" parent="1">
          <mxGeometry x="685" y="430" width="60" height="60" as="geometry" />
        </mxCell>
        <mxCell id="cw" value="CloudWatch&#10;logs, metrics, alarms" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#E7157B;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.cloudwatch;" vertex="1" parent="1">
          <mxGeometry x="685" y="540" width="60" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ecr" value="ECR&#10;cloud images" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#ED7100;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.elastic_container_registry;" vertex="1" parent="1">
          <mxGeometry x="685" y="650" width="60" height="60" as="geometry" />
        </mxCell>
        <mxCell id="gpus" value="GPU pool, RunPod / vast.ai, outside AWS&#10;same worker image self-hosters run" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="960" y="280" width="260" height="90" as="geometry" />
        </mxCell>
        <mxCell id="r2" value="Cloudflare R2&#10;model weights mirror, zero egress" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="960" y="440" width="260" height="70" as="geometry" />
        </mxCell>
        <mxCell id="stripe" value="Stripe&#10;checkout, portal, tax, webhooks" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="960" y="580" width="260" height="70" as="geometry" />
        </mxCell>
        <mxCell id="ke1" value="DNS" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="1" source="cuser" target="r53">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ke2" value="assets" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="1" source="cuser" target="cf">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ke3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="1" source="cf" target="s3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ke4" value="REST + WS" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="1" source="cuser" target="alb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ke5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="1" source="alb" target="ecs">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ke6" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="1" source="ecs" target="rds">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ke7" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="1" source="ecs" target="ec">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ke8" value="quota, metering" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="1" source="ecs" target="priv">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ke9" value="outbound WSS only&#10;to the fleet endpoint" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="1" source="gpus" target="alb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ke10" value="rents machines&#10;hard spend cap" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;dashed=1;" edge="1" parent="1" source="priv" target="gpus">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ke11" value="weights at boot" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;dashed=1;" edge="1" parent="1" source="gpus" target="r2">
