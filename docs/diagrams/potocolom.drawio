        <mxCell id="adGate" value="manual approval&#10;GitHub environment&#10;protection" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
