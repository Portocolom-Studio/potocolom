        <mxCell id="adId" value="Identity" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;verticalAlign=top;fontStyle=1;fontSize=12;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="800" y="430" width="400" height="240" as="geometry" />
        </mxCell>
        <mxCell id="adId1" value="Humans: IAM Identity Center, no long-lived keys.&#10;ReadOnly daily, Admin break-glass (then codified).&#10;&#10;Pipelines: GitHub OIDC only; the public repo has&#10;no AWS access at all - its release ends at GHCR.&#10;&#10;Workloads: execution role (image + own SSM prefix)&#10;plus a task role limited to what the code does.&#10;Workers are not AWS principals: rented machines,&#10;short-lived fleet tokens to the API." style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="815" y="458" width="370" height="200" as="geometry" />
        </mxCell>
        <mxCell id="adMgmt" value="Management account: consolidated billing + organization CloudTrail, no workloads" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="700" width="720" height="40" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="metrics-observability" name="Metrics and observability">
    <mxGraphModel dx="1400" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1240" pageHeight="660" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="moTitle" value="Metrics and observability - four planes, one export path each" style="text;html=1;align=left;verticalAlign=middle;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="14" width="1160" height="30" as="geometry" />
        </mxCell>
        <mxCell id="moSub" value="Workers export over the connection they already hold and are never AWS principals; aggregates become CloudWatch metrics, per-worker detail stays in Redis and logs; no client-side analytics anywhere." style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="46" width="1160" height="20" as="geometry" />
        </mxCell>
        <mxCell id="moW" value="GPU workers - one process per GPU&#10;NVML / amd-smi sample on every 30 s heartbeat&#10;(util, VRAM, temperature, power)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="84" width="270" height="90" as="geometry" />
        </mxCell>
        <mxCell id="moAPI" value="API replicas + private services&#10;JSON logs + PutMetricData" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="214" width="270" height="70" as="geometry" />
