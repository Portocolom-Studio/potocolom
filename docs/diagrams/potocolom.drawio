        </mxCell>
        <mxCell id="adE3" value="pin" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;" edge="1" parent="1" source="adPub3" target="adPriv1"><mxGeometry relative="1" as="geometry" /></mxCell>
