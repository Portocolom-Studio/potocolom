<mxfile host="app.diagrams.net" type="device">
  <diagram id="overview" name="System overview">
    <mxGraphModel dx="1000" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="browser" value="Browser&#10;SvelteKit SPA" style="sketch=0;outlineConnect=0;fontColor=#232F3E;fillColor=#232F3E;html=1;verticalLabelPosition=bottom;verticalAlign=top;aspect=fixed;shape=mxgraph.aws4.users;" vertex="1" parent="1">
          <mxGeometry x="60" y="280" width="78" height="78" as="geometry" />
        </mxCell>
        <mxCell id="api" value="API server&#10;FastAPI, stateless" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="380" y="270" width="200" height="90" as="geometry" />
        </mxCell>
        <mxCell id="pg" value="PostgreSQL&#10;source of truth" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="380" y="480" width="120" height="90" as="geometry" />
        </mxCell>
        <mxCell id="store" value="Object storage&#10;local disk or S3" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="560" y="480" width="120" height="90" as="geometry" />
        </mxCell>
        <mxCell id="worker" value="Inference worker&#10;diffusers + PyTorch&#10;DEVICE: cuda | rocm | cpu" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="800" y="260" width="220" height="110" as="geometry" />
        </mxCell>
        <mxCell id="seams" value="Pluggable seams: auth mode, dispatch, quota, storage&#10;Self-hosted and cloud differ only in configuration" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="330" y="80" width="440" height="70" as="geometry" />
        </mxCell>
        <mxCell id="e1" value="HTTP: SPA + REST&#10;WS: /api/v1/realtime" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="1" source="browser" target="api">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" value="SQL" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="1" source="api" target="pg">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" value="storage adapter" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="1" source="api" target="store">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" value="dials out, one persistent WS&#10;/api/v1/fleet" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="1" source="worker" target="api">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
